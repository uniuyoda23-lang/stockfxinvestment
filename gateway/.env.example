# Gateway configuration for local development
# Copy this as .env and adjust for your environment

# Gateway server
GATEWAY_PORT=4000
GATEWAY_HOST=localhost
NODE_ENV=development

# Backend service URLs (must match running instances)
AUTH_SERVICE_URL=http://localhost:3000
DASHBOARD_SERVICE_URL=http://localhost:3001
ACCOUNT_SERVICE_URL=http://localhost:3002
OTP_SERVICE_URL=http://localhost:3003

# CORS allowed origins (comma-separated or single)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
